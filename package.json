{
  "name": "aeolus-installer",
  "version": "1.0.0",
  "private": true,
  "description": "Aeolus AI Tools Installer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "postbuild": "cp -r \"dist/mac-arm64/Aeolus Installer.app\" \"../Aeolus Installer.app\" 2>/dev/null || cp -r \"dist/mac/Aeolus Installer.app\" \"../Aeolus Installer.app\" 2>/dev/null || true"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.aeolus.installer",
    "productName": "Aeolus Installer",
    "mac": {
      "target": "dir",
      "icon": "assets/icon.icns"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "Aeolus",
        "to": "Aeolus",
        "filter": ["**/*", "!**/node_modules/**", "!**/.venv/**", "!**/*.app"]
      }
    ]
  }
}
